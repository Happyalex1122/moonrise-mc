     private static final int EMPTY_TIME_NO_TICK = 300;
     private static final int MAX_SCHEDULED_TICKS_PER_TICK = 65536;
+    private static final long THROTTLE_THRESHOLD_NS = 45_000_000L;
     private final List<ServerPlayer> players = Lists.newArrayList();
     public final ServerChunkCache chunkSource;
     private final MinecraftServer server;
@@ -781,6 +782,7 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
     }
 
     public void tick(final BooleanSupplier haveTime) {
+        long tickStartTime = System.nanoTime();
         ProfilerFiller profiler = Profiler.get();
         this.handlingTick = true;
         TickRateManager tickRateManager = this.tickRateManager();
@@ -866,6 +868,8 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
             }
 
             io.papermc.paper.entity.activation.ActivationRange.activateEntities(this); // Paper - EAR
+            int[] count = {0};
+            long[] lastTime = {tickStartTime};
             this.entityTickList
                 .forEach(
                     entity -> {
@@ -884,6 +888,17 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
                                         entity.stopRiding();
                                     }
 
+                                    if (count[0]++ % 20 == 0) {
+                                        lastTime[0] = System.nanoTime();
+                                    }
+                                    if (lastTime[0] - tickStartTime > THROTTLE_THRESHOLD_NS) {
+                                        if (!(entity instanceof net.minecraft.world.entity.player.Player) &&
+                                            !(entity instanceof net.minecraft.world.entity.projectile.Projectile) &&
+                                            !(entity instanceof net.minecraft.world.entity.item.ItemEntity)) {
+                                            return;
+                                        }
+                                    }
+
                                     profiler.push("tick");
                                     this.guardEntityTick(this::tickNonPassenger, entity);
                                     profiler.pop();
