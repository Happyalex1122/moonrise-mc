diff --git a/ca/spottedleaf/moonrise/common/list/BatchedRcuEntityList.java b/ca/spottedleaf/moonrise/common/list/BatchedRcuEntityList.java
index cccafe57f1c0e9b12ce9c2845588a8cd5321c038..184e3db00cbbf704e098820de5600933942f46d9 100644
--- a/ca/spottedleaf/moonrise/common/list/BatchedRcuEntityList.java
+++ b/ca/spottedleaf/moonrise/common/list/BatchedRcuEntityList.java
@@ -3,8 +3,8 @@ package ca.spottedleaf.moonrise.common.list;
 import java.lang.invoke.MethodHandles;
 import java.lang.invoke.VarHandle;
 import java.util.Arrays;
-import java.util.Queue;
-import java.util.concurrent.ConcurrentLinkedQueue;
+import java.util.Set;
+import java.util.concurrent.ConcurrentHashMap;
 import java.util.function.Consumer;
 import net.minecraft.world.entity.Entity;
 
@@ -20,23 +20,23 @@ public class BatchedRcuEntityList {
         }
     }
 
-    private final Queue<Entity> addQueue = new ConcurrentLinkedQueue<>();
-    private final Queue<Entity> removeQueue = new ConcurrentLinkedQueue<>();
+    private final Set<Entity> addSet = ConcurrentHashMap.newKeySet();
+    private final Set<Entity> removeSet = ConcurrentHashMap.newKeySet();
 
     public void add(Entity e) {
         if (e == null) return;
-        addQueue.offer(e);
+        addSet.add(e);
     }
 
     public void remove(Entity e) {
         if (e == null) return;
-        removeQueue.offer(e);
+        removeSet.add(e);
     }
 
     public boolean contains(Entity e) {
         if (e == null) return false;
-        if (addQueue.contains(e)) return true;
-        if (removeQueue.contains(e)) return false;
+        if (addSet.contains(e)) return true;
+        if (removeSet.contains(e)) return false;
 
         Entity[] current = (Entity[]) ELEMENTS_HANDLE.getAcquire(this);
         for (Entity o : current) {
@@ -46,9 +46,6 @@ public class BatchedRcuEntityList {
     }
 
     public void forEachAcquire(Consumer<? super Entity> action) {
-        // We flush queues before ticking.
-        commitChanges();
-
         Entity[] snapshot = (Entity[]) ELEMENTS_HANDLE.getAcquire(this);
         for (Entity e : snapshot) {
             if (e != null && !e.isRemoved()) {
@@ -58,23 +55,21 @@ public class BatchedRcuEntityList {
     }
 
     public synchronized void commitChanges() {
-        if (addQueue.isEmpty() && removeQueue.isEmpty()) return;
+        if (addSet.isEmpty() && removeSet.isEmpty()) return;
 
         Entity[] current = (Entity[]) ELEMENTS_HANDLE.getAcquire(this);
 
-        int newSize = current.length + addQueue.size();
+        int newSize = current.length + addSet.size();
         Entity[] next = new Entity[newSize];
 
         int idx = 0;
         for (Entity e : current) {
-            if (e != null && !e.isRemoved() && !removeQueue.contains(e)) {
+            if (e != null && !e.isRemoved() && !removeSet.contains(e)) {
                 next[idx++] = e;
             }
         }
 
-        Entity toAdd;
-        while ((toAdd = addQueue.poll()) != null) {
-            // Avoid duplicates
+        for (Entity toAdd : addSet) {
             boolean exists = false;
             for (int i = 0; i < idx; i++) {
                 if (next[i] == toAdd) {
@@ -90,6 +85,7 @@ public class BatchedRcuEntityList {
         next = Arrays.copyOf(next, idx);
 
         ELEMENTS_HANDLE.setRelease(this, next);
-        removeQueue.clear();
+        addSet.clear();
+        removeSet.clear();
     }
 }
