+package ca.spottedleaf.moonrise.common.list;
+
+import java.lang.invoke.MethodHandles;
+import java.lang.invoke.VarHandle;
+import java.util.Arrays;
+import java.util.function.Consumer;
+
+public class RcuList<E> {
+    private volatile Object[] elements;
+    private static final VarHandle ELEMENTS_HANDLE;
+
+    static {
+        try {
+            ELEMENTS_HANDLE = MethodHandles.lookup().findVarHandle(RcuList.class, "elements", Object[].class);
+        } catch (ReflectiveOperationException e) {
+            throw new ExceptionInInitializerError(e);
+        }
+    }
+
+    public RcuList() {
+        this.elements = new Object[0];
+    }
+
+    @SuppressWarnings("unchecked")
+    public void forEachAcquire(Consumer<? super E> action) {
+        final Object[] snapshot = (Object[]) ELEMENTS_HANDLE.getAcquire(this);
+        for (Object element : snapshot) {
+            if (element != null) {
+                action.accept((E) element);
+            }
+        }
+    }
+
+    public synchronized void add(E element) {
+        Object[] current = (Object[]) ELEMENTS_HANDLE.getAcquire(this);
+        // Do not add duplicates or null
+        if (element == null) return;
+        for (Object o : current) {
+            if (o == element) return;
+        }
+
+        Object[] next = Arrays.copyOf(current, current.length + 1);
+        next[current.length] = element;
+        ELEMENTS_HANDLE.setRelease(this, next);
+    }
+
+    public synchronized void remove(E element) {
+        if (element == null) return;
+        Object[] current = (Object[]) ELEMENTS_HANDLE.getAcquire(this);
+        int index = -1;
+        for (int i = 0; i < current.length; i++) {
+            if (current[i] == element) {
+                index = i;
+                break;
+            }
+        }
+        if (index >= 0) {
+            Object[] next = new Object[current.length - 1];
+            System.arraycopy(current, 0, next, 0, index);
+            System.arraycopy(current, index + 1, next, index, current.length - 1 - index);
+            ELEMENTS_HANDLE.setRelease(this, next);
+        }
+    }
+
+    public boolean contains(E element) {
+        if (element == null) return false;
+        Object[] current = (Object[]) ELEMENTS_HANDLE.getAcquire(this);
+        for (Object o : current) {
+            if (o == element) return true;
+        }
+        return false;
+    }
+}
