package net.minecraft.server.region;

import java.util.Queue;
import java.util.concurrent.ConcurrentLinkedQueue;

/**
 * Region 간 메시지 패싱(Actor Model)을 지원하기 위해 설계된 Lock-free MPSC 메시지 큐입니다.
 * ConcurrentLinkedQueue를 기반으로 하여 여러 스레드가 동시에 안전하게 메시지(Intent)를 보낼 수 있으며,
 * 단일 RegionThread가 순차적으로 메시지를 소비(Consume)합니다.
 */
public class RegionMessageQueue {

    /**
     * Region 간에 주고받는 메시지 및 비동기 작업의 의도를 정의하는 인터페이스입니다.
     */
    @FunctionalInterface
    public interface RegionIntent {
        /**
         * 대상 RegionThread 컨텍스트 내에서 실행할 로직을 정의합니다.
         */
        void execute();
    }

    // Lock-free MPSC(Multi-Producer Single-Consumer) Queue
    private final Queue<RegionIntent> queue = new ConcurrentLinkedQueue<>();

    /**
     * 대상 Region 스레드에서 비동기로 실행할 Intent를 큐에 안전하게 추가합니다. (Thread-safe)
     * 이 메서드는 다른 RegionThread나 메인 스레드(Producer)에서 호출됩니다.
     *
     * @param intent 실행할 의도가 담긴 Intent 객체
     */
    public void add(RegionIntent intent) {
        if (intent != null) {
            queue.add(intent);
        }
    }

    /**
     * 현재 큐에 쌓여 있는 모든 Intent를 순차적으로 꺼내어 실행합니다.
     * 이 메서드는 오직 해당 Region을 담당하는 전담 스레드(Single Consumer)에서만 호출되어야 합니다.
     */
    public void processAll() {
        RegionIntent intent;
        while ((intent = queue.poll()) != null) {
            try {
                intent.execute();
            } catch (Throwable t) {
                // 특정 작업의 실패가 전체 루프나 스레드 정지를 유발하지 않도록 예외 처리
                // NMS 환경에서는 서버 로거를 통해 기록하는 것이 권장됩니다.
                System.err.println("Error processing region intent: " + t.getMessage());
                t.printStackTrace();
            }
        }
    }

    /**
     * 큐가 비어있는지 확인합니다.
     *
     * @return 큐가 비어있으면 true
     */
    public boolean isEmpty() {
        return queue.isEmpty();
    }

    /**
     * 현재 대기 중인 Intent의 개수를 반환합니다.
     *
     * @return 큐의 크기
     */
    public int size() {
        return queue.size();
    }
}
